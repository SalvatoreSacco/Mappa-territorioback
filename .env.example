# Database (Neon DB or any PostgreSQL with PostGIS)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=8h

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3001

# Server
PORT=3000

# Default admin credentials (used only when admin_users table is empty)
ADMIN_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=changeme123

# Path to the GeoJSON file used by the import endpoint
IMPORT_FILE_PATH=comuni.geojson
